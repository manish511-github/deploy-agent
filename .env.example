# LLM
GEMINI_API_KEY=your-gemini-key-here

# Database (your existing linux-server-manager PostgreSQL)
DATABASE_URL=postgresql://lsm_user:lsm_password@localhost:5432/linux_server_manager

# SSH Defaults
SSH_KEY_PATH=~/.ssh/id_rsa
SSH_DEFAULT_USER=root
SSH_TIMEOUT=30

# LLM Model
LLM_MODEL=gemini-2.5-flash-lite
LLM_TEMPERATURE=0
